# AskElira Framework — Environment Configuration
# Copy to .env and fill in your values

# ── Required ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── MiroFish (self-hosted simulation backend) ──────────────────────────
# Start with: docker-compose up  (see github.com/Shanda-Group/MiroFish)
MIROFISH_URL=http://localhost:5001

# ── Optional: Pinecone long-term memory ───────────────────────────────
# PINECONE_API_KEY=your_pinecone_key_here
# PINECONE_INDEX_NAME=askelira-memory

# ── Optional: domain-specific keys ────────────────────────────────────
# Trader:    POLYMARKET_KEY, KALSHI_EMAIL, KALSHI_PASSWORD
# Marketing: GITHUB_TOKEN, OPENAI_API_KEY, REPLICATE_API_TOKEN
